# Copy this file to `.env` and fill in your keys.
# `.env` is gitignored — it will never be committed.

# Your Ashby team API key. Required for the MCP server itself
# (stdio or HTTP transport). Not needed for eval runs — evals use
# synthetic data via a fake HTTP transport.
ASHBY_API_KEY=

# Your Anthropic API key. Required only for running evals
# (`uv run python -m evals.run`). Get one at console.anthropic.com.
ANTHROPIC_API_KEY=

# Optional — override the model used for eval runs.
# Default: claude-sonnet-4-6
# ASHBY_EVAL_MODEL=claude-opus-4-7

# Optional — override the judge model used for eval grading.
# Default: claude-haiku-4-5-20251001
# ASHBY_EVAL_JUDGE_MODEL=claude-sonnet-4-6

# Optional — force raw JSON output from tools instead of markdown tables.
# ASHBY_OUTPUT=json

# Optional — bearer token for the HTTP/SSE transport (Claude Cowork).
# Leave unset for stdio-only local usage.
# MCP_BEARER_TOKEN=
